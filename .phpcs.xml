<?xml version="1.0"?>
<ruleset name="MoodleQuizGame">
    <description>Moodle CodeSniffer configuration.</description>
    <rule ref="moodle"/>
    <file>.</file>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/lib/audiowide/*</exclude-pattern>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg value="s"/>
    <arg value="p"/>
</ruleset>
